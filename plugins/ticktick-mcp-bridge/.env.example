PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787

# TickTick developer app credentials from https://developer.ticktick.com/manage
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=

# Must match a redirect URI registered in the TickTick developer app.
# For local testing:
TICKTICK_REDIRECT_URI=http://127.0.0.1:8787/oauth/callback

# Optional: use an already-issued TickTick OAuth access token instead of local OAuth storage.
TICKTICK_ACCESS_TOKEN=
TICKTICK_REFRESH_TOKEN=
TICKTICK_TOKEN_EXPIRES_AT=

# Optional shared secret for your MCP endpoint.
# If set, ChatGPT/API callers must send Authorization: Bearer <APP_SHARED_SECRET>.
APP_SHARED_SECRET=

# Optional local token store location.
# Leave empty to share the default Codex/ChatGPT store:
# %APPDATA%\Codex\ticktick-assistant\auth.json
TICKTICK_AUTH_FILE=
