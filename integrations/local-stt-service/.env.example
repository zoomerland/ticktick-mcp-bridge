STT_HOST=127.0.0.1
STT_PORT=9876
STT_PROVIDER=mock
STT_MOCK_TRANSCRIPT=synthetic local transcript
STT_BEARER_TOKEN=replace-with-local-bearer-token
STT_MAX_AUDIO_BYTES=10485760
STT_LOG_REQUESTS=false

# Command provider example. Keep STT_PROVIDER=mock until a local command is ready.
STT_COMMAND=path-to-local-stt-command
STT_COMMAND_ARGS=["{audio}"]
STT_COMMAND_TIMEOUT_MS=30000
