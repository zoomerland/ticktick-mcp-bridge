STT_HOST=127.0.0.1
STT_PORT=9876
STT_PROVIDER=mock
STT_MOCK_TRANSCRIPT=synthetic local transcript
STT_BEARER_TOKEN=replace-with-local-bearer-token
STT_MAX_AUDIO_BYTES=10485760
STT_LOG_REQUESTS=false
STT_LOG_TIMINGS=true

# Command provider example. Keep STT_PROVIDER=mock until a local command is ready.
STT_COMMAND=path-to-local-stt-command
STT_COMMAND_ARGS=["{audio}"]
STT_COMMAND_TIMEOUT_MS=30000

# SenseVoiceSmall command provider example.
# Keep STT_PROVIDER=mock until dependencies and model artifacts are installed
# outside this repository.
# STT_PROVIDER=command
# STT_COMMAND=python
# STT_COMMAND_ARGS=["providers/sensevoice_transcribe.py","{audio}"]
# STT_COMMAND_TIMEOUT_MS=120000
# SENSEVOICE_MODEL=FunAudioLLM/SenseVoiceSmall
# SENSEVOICE_DEVICE=cpu
# SENSEVOICE_HUB=hf
# SENSEVOICE_LANGUAGE=auto
# SENSEVOICE_USE_ITN=true
# SENSEVOICE_ENABLE_VAD=false
# SENSEVOICE_PRECONVERT=true
# SENSEVOICE_DISABLE_UPDATE=true

# Resident SenseVoiceSmall HTTP server example. This keeps the model loaded
# until the process is stopped.
# python providers/sensevoice_server.py
